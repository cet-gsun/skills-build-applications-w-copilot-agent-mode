# Example frontend environment variables for OctoFit Tracker
#
# When running in GitHub Codespaces, define VITE_CODESPACE_NAME so the app can
# target the Codespaces backend URL.
#
# For example:
# VITE_CODESPACE_NAME=my-codespace-name

# VITE_CODESPACE_NAME must be defined in .env.local when deploying from GitHub Codespaces.
# When this variable is unset during development, the app safely falls back to /api
# (the Vite proxy) or http://localhost:8000/api.
VITE_CODESPACE_NAME=
